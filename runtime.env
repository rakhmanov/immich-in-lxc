# https://immich.app/docs/install/environment-variables/

# Immich
TZ=America/New_York
IMMICH_VERSION=release
IMMICH_ENV=production

# Postgresql
DB_HOSTNAME=localhost
DB_USERNAME=immich
# pre-install.sh overwrites DB_PASSWORD with the password you chose during
# bootstrap. If you are setting this up manually, replace the placeholder
# below with the password of your PostgreSQL 'immich' role. If it contains
# '$', '!', or other shell-special characters, keep the single quotes.
DB_PASSWORD='A_SEHR_SAFE_PASSWORD'
DB_DATABASE_NAME=immich
# VectorChord is now the recommended vector extension (v1.133.0+)
DB_VECTOR_EXTENSION=vectorchord

# Redis
REDIS_HOSTNAME=localhost

# Machine learning
# pre-install.sh and install.sh rewrite this default to match the selected
# service user's home / install directory on first setup.
MACHINE_LEARNING_CACHE_FOLDER=/home/immich/ml-models
